{
  "_comment": "Copy to /etc/ktp/audit-fleet.json (mode 600, root-owned) or point KTP_AUDIT_FLEET_CONFIG at your own location. Do NOT commit the real file — it contains SSH credentials. See scripts/audit-fleet-drift.py for the schema.",

  "hosts": [
