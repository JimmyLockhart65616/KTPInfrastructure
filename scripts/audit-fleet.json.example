  "_auth_notes": [
    "password:     plaintext SSH password (simplest; matches existing dodserver creds)",
    "key_filename: path to SSH private key (use instead of password for key-based auth)",
    "If both are omitted, paramiko falls back to agent + ~/.ssh/id_* key discovery.",
    "Migrate to key_filename when feasible — the shared dodserver password is weak."
  ]
}
