#!/bin/bash
# KTP: daily cleanup of orphan HLTV recordings.
#
# Deletes auto_*.dem files >7d old in /home/hltvserver/hlds/dod root.
# These are HLTV captures that occurred outside any KTP match window
# (no ktp_match_start emitted during the recording, so hltv-demo-renamer
# left them unattributed). After 7d they have no retrieval value —
# filename only carries host+timestamp, no match_id to search.
#
# Renamer abandon-window for legit-late attribution is 14400s (4h);
# 7d is well past any rename-retry concern.
#
# Install: scp this file to /etc/cron.daily/ktp-orphan-cleanup on the data
# server (74.91.112.242), chmod 755, touch /var/log/ktp-orphan-cleanup.log.
# Reversible: rm /etc/cron.daily/ktp-orphan-cleanup
set -euo pipefail
TARGET_DIR=/home/hltvserver/hlds/dod
LOG=/var/log/ktp-orphan-cleanup.log

count=$(find "$TARGET_DIR" -maxdepth 1 -name "auto_*.dem" -mtime +7 2>/dev/null | wc -l)
bytes=$(find "$TARGET_DIR" -maxdepth 1 -name "auto_*.dem" -mtime +7 -printf "%s\n" 2>/dev/null | awk '{s+=$1} END {print s+0}')
find "$TARGET_DIR" -maxdepth 1 -name "auto_*.dem" -mtime +7 -delete 2>>"$LOG" || true
mb=$(awk -v b="$bytes" 'BEGIN { printf "%.1f", b/1048576 }')
printf "%s deleted=%d bytes=%d (%s MB)\n" "$(date -Is)" "$count" "$bytes" "$mb" >> "$LOG"
